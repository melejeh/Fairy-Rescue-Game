  m_Script: {fileID: 11500000, guid: 63e0e3379ff0f4d0e9cdfade3a616a45, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  bubbleText: {fileID: 1434311714}
  objectiveText: {fileID: 0}
  dialogueLines:
  - Hi! Welcome to Fairy Rescue! An evil wizard has taken my friend hostage in the
    third world. You must collect keys to unlock each portal to reach him. Come back
    to me after each level for guidance!
  - Great work! You found the first key, but there is still another hidden here in
    the first world. Drop that key in the chest, then head back through Portal 1
    to find the next one
  - You've got the second key! Drop it in the chest to power up the gateway, then
    head through Portal 2 to continue your search.
  - Excellent! You've secured the first key of this realm, but the wizard's magic
    is strong. Deposit the key and return to Portal 2; there is one more fragment
    remaining.
  - "That's it! You have the second key. Drop it off and prepare yourself\u2014head
    into Portal 3 for the final key!"
  - You did it! The land is safe, the wizard is defeated, and my friend is finally
    free. You are a true hero of the Fairy Realm!
  objectiveLines:
  - 'GOAL: Find the first key.'
  - 'GOAL: Return to portal 1.'
  - 'GOAL: Enter portal 2.'
  - 'GOAL: Search portal 2 again.'
  - 'GOAL: Enter portal 3.'
  - Mission complete!
  waitTime: 5
