  m_Script: {fileID: 11500000, guid: 63e0e3379ff0f4d0e9cdfade3a616a45, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  bubbleText: {fileID: 1396561397}
  firstTalkLines:
  - Welcome, little fairy!
  - Use the arrow keys to move through the world.
  - Press the Space bar when you are near me to talk.
  - Each portal holds a new challenge and a hidden key.
  - Some levels contain power-ups that will help you.
  - Bring each key back and deposit it in the chest.
  - Doing this will unlock new paths ahead.
  - Your first task is to enter Portal 1.
  repeatTalkLines:
  - Press Space when you are near me if you need help again.
  - Remember to use the arrow keys to move.
  - Look out for power-ups in each level.
  - If you have a key, deposit it in the chest.
  lineDuration: 3
